# Database
DATABASE_URL=postgresql+asyncpg://ragr:ragr@localhost:5432/ragr

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# Clerk auth (required)
CLERK_SECRET_KEY=sk_live_...
SUPERUSER_ID=

# Encryption (for custom API key storage)
ENCRYPTION_KEY=

# Console CORS origins (JSON array)
CONSOLE_ORIGINS=["http://localhost:5173"]

# Cloudflare R2 (optional — enables presigned upload flow)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ragr-uploads

# Rate limiting
RATE_LIMIT_PER_MIN=10

# RAG defaults (used when creating new models)
DEFAULT_SIMILARITY_THRESHOLD=0.5
DEFAULT_TOP_K=15
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=100
DEFAULT_BUDGET_LIMIT=10.0
DEFAULT_GENERATION_MODEL=claude-haiku-4-5
DEFAULT_EMBEDDING_MODEL=voyage-4-lite
DEFAULT_RERANK_MODEL=rerank-2.5-lite
